# URL de l'API (Railway) - doit inclure https:// et /api
VITE_API_URL=https://stickerstreet-production.up.railway.app/api

# URL de la webapp (VPS/ngrok ou domaine) - pour TON Connect
VITE_APP_URL=https://unjogging-socorro-lobularly.ngrok-free.dev

# Adresse wallet TON pour recevoir les paiements
VITE_TON_MERCHANT_ADDRESS=

# Username du bot Telegram (ex: StickerStreetBot) pour le lien inscription
VITE_TELEGRAM_BOT_USERNAME=StickerStreetBot

# Base de données : gérée par l'API (Neon ou fichier JSON). Pas de config DB ici.
